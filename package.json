{
	"name": "verseconnect",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"main": "src/main/index.js",
	"author": "Ulong32",
	"description": "An PriPhoto Management App",
	"scripts": {
		"dev": "set NODE_ENV=dev && npm run dev:all",
		"dev:all": "concurrently -n=svelte,electron -c='#ff3e00',blue \"npm run dev:svelte\" \"npm run dev:electron\"",
		"dev:svelte": "vite dev",
		"dev:electron": "electron src/main/index.js",
		"build": "cross-env NODE_ENV=production npm run build:svelte && npm run build:electron",
		"build:svelte": "vite build",
		"build:electron": "electron-builder -w --config build.config.json",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@skeletonlabs/skeleton": "^4.10.0",
		"@skeletonlabs/skeleton-svelte": "^4.10.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.0",
		"@sveltejs/mcp": "^0.1.19",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.1.18",
		"@types/adm-zip": "^0.5.7",
		"@vitest/browser-playwright": "^4.0.17",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"electron": "^39.2.7",
		"electron-builder": "^26.5.0",
		"electron-packager": "^17.1.2",
		"electron-reloader": "^1.2.3",
		"electron-updater": "^6.8.1",
		"playwright": "^1.57.0",
		"svelte": "^5.47.1",
		"svelte-check": "^4.3.5",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.17",
		"vitest-browser-svelte": "^2.0.1"
	},
	"dependencies": {
		"@lucide/svelte": "^0.562.0",
		"adm-zip": "^0.5.16",
		"electron-context-menu": "^4.1.1",
		"electron-serve": "^3.0.0",
		"electron-store": "^11.0.2",
		"electron-window-state": "^5.0.3"
	},
	"volta": {
		"node": "24.13.0"
	}
}
