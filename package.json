{
  "name": "verseconnect",
  "version": "0.1.0",
  "private": true,
  "description": "An PriPhoto Management App",
  "author": "Ulong32",
  "type": "module",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "set NODE_ENV=dev && npm run dev:all",
    "dev:all": "concurrently -n=svelte,electron -c='#ff3e00',blue \"npm run dev:svelte\" \"npm run dev:electron\"",
    "dev:svelte": "vp dev",
    "dev:electron": "electron src/main/index.js",
    "build": "cross-env NODE_ENV=production npm run build:svelte && npm run build:electron",
    "build:svelte": "vp build",
    "build:electron": "electron-builder -w --config build.config.json",
    "preview": "vp preview",
    "prepare": "vp config && svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vp test",
    "test": "npm run test:unit -- --run"
  },
  "dependencies": {
    "@lucide/svelte": "^1.7.0",
    "adm-zip": "^0.5.17",
    "electron-context-menu": "^4.1.2",
    "electron-serve": "^3.0.1",
    "electron-store": "^11.0.2",
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "@skeletonlabs/skeleton": "^4.14.0",
    "@skeletonlabs/skeleton-svelte": "^4.14.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/mcp": "^0.1.22",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.2",
    "@types/adm-zip": "^0.5.8",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "electron-reloader": "^1.2.3",
    "electron-updater": "^6.8.3",
    "playwright": "^1.59.1",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vitest-browser-svelte": "^2.1.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "volta": {
    "node": "24.13.0"
  },
  "packageManager": "npm@11.12.1"
}
