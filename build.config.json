{
  "appId": "net.ulong32.verseconnect",
  "productName": "VerseConnect",
  "publish": {
    "provider": "github",
    "owner": "ulong32",
    "repo": "VerseConnect"
  },
  "directories": {
    "output": "dist"
  },
  "files": [
    "src/main/**/*",
    "src/preload.cjs",
    "src/lib/assets/favicon.png",
    {
      "from": "build",
      "to": ""
    }
  ],
  "win": {
    "target": ["nsis", "portable"],
    "icon": "src/lib/assets/favicon.png"
  },
  "nsis": {
    "artifactName": "${productName}.Setup.${version}.${ext}"
  },
  "portable": {
    "artifactName": "${productName}.Portable.${version}.${ext}"
  }
}
